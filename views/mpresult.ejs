<%- include('partials/header', {
  pageTitle: 'Menopause Forecast Result — e-healthwatch',
  pageDesc:  'Your personalised menopause forecast result based on your AMH value, age, and cycle regularity.'
}) %>

<div class="fc-result-bg">
  <div class="fc-result-inner">

    <!-- ─── Result hero card ────────────────────────────────────── -->
    <div class="fc-result-hero">
      <div class="fc-result-hero-top">
        <div class="fc-result-name-pill">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <%= name %>
        </div>
        <div class="fc-result-badge">Menopause Forecast</div>
      </div>

      <div class="fc-result-number-wrap">
        <div class="fc-result-big"><%= fmvalue %></div>
        <div class="fc-result-big-label">Estimated age of menopause onset</div>
      </div>

      <div class="fc-result-chips">
        <div class="fc-result-chip">Age: <strong><%= age %> yrs</strong></div>
        <div class="fc-result-chip">AMH: <strong><%= amhvalue %> ng/mL</strong></div>
        <div class="fc-result-chip">Cycle: <strong><%= periods %></strong></div>
      </div>
    </div>

    <!-- ─── Two-column: interpretation + save ──────────────────── -->
    <div class="fc-result-grid">

      <!-- Interpretation -->
      <div class="fc-result-interp">
        <h2 class="fc-result-section-title">What your result means</h2>

        <%
          var diff = fmvalue - parseInt(age);
          var amhNum = parseFloat(amhvalue);
        %>

        <% if (diff >= 15) { %>
        <div class="fc-interp-band fc-interp-band--green">
          <div class="fc-interp-icon">🌿</div>
          <div>
            <strong>Well-preserved ovarian reserve</strong>
            <p>Your AMH of <strong><%= amhvalue %> ng/mL</strong> is consistent with a healthy ovarian reserve for your age. Based on our model, you have approximately <strong><%= diff %> years</strong> before natural menopause — comfortably within the typical range.</p>
          </div>
        </div>
        <% } else if (diff >= 8) { %>
        <div class="fc-interp-band fc-interp-band--amber">
          <div class="fc-interp-icon">🌸</div>
          <div>
            <strong>Typical ovarian reserve</strong>
            <p>Your AMH of <strong><%= amhvalue %> ng/mL</strong> suggests a typical ovarian reserve for your age. Your estimated <strong><%= diff %> years</strong> to menopause is within the normal range. Regular monitoring with annual AMH tests is a good idea.</p>
          </div>
        </div>
        <% } else { %>
        <div class="fc-interp-band fc-interp-band--rose">
          <div class="fc-interp-icon">💬</div>
          <div>
            <strong>Consider speaking to your gynaecologist</strong>
            <p>Your AMH of <strong><%= amhvalue %> ng/mL</strong> suggests your ovarian reserve may be lower than average for your age. This does not mean there is a problem, but we recommend discussing this result with a gynaecologist who can provide a full clinical assessment.</p>
          </div>
        </div>
        <% } %>

        <!-- AMH context facts -->
        <div class="fc-fact-grid">
          <div class="fc-fact-card">
            <div class="fc-fact-icon">📊</div>
            <div>
              <strong>Why AMH is reliable</strong>
              <p>AMH is the most accurate single predictor of menopause timing, outperforming FSH and antral follicle count in long-term cohort studies.</p>
            </div>
          </div>
          <div class="fc-fact-card">
            <div class="fc-fact-icon">🔄</div>
            <div>
              <strong>Track over time</strong>
              <p>AMH naturally declines with age. Retesting annually lets you see how your ovarian reserve is changing and update your forecast.</p>
            </div>
          </div>
          <div class="fc-fact-card">
            <div class="fc-fact-icon">🌡️</div>
            <div>
              <strong>Perimenopause signs</strong>
              <p>Hot flushes, irregular cycles, and sleep changes often begin 4–8 years before menopause. Your forecast can help you prepare.</p>
            </div>
          </div>
          <div class="fc-fact-card">
            <div class="fc-fact-icon">🦴</div>
            <div>
              <strong>Bone health</strong>
              <p>Oestrogen decline around menopause accelerates bone density loss. Early awareness lets you start preventive steps like calcium and vitamin D supplementation.</p>
            </div>
          </div>
        </div>

        <!-- Disclaimer -->
        <div class="fc-result-disclaimer">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>This forecast is a <strong>statistical estimate</strong> based on published research (power regression model). It is not a clinical diagnosis. Individual results may vary due to health conditions, medications, and genetic factors. Please consult a gynaecologist for personalised advice.</span>
        </div>
      </div>

      <!-- Save / actions panel -->
      <div class="fc-result-actions-panel">

        <% if (!locals.consumerId) { %>
        <!-- Not logged in: upsell account -->
        <div class="fc-save-panel">
          <div class="fc-save-panel-icon">💾</div>
          <h3>Save this result</h3>
          <p>Create a free account and pay ₹49 once to permanently store your forecast — view it anytime, and retake with a new AMH value later.</p>
          <ul class="fc-save-benefits">
            <li>✓ Result saved to your profile forever</li>
            <li>✓ Track 3 profiles (self, mother, sister)</li>
            <li>✓ Retake anytime — see how your forecast changes</li>
            <li>✓ One-time ₹49 · No subscription</li>
          </ul>
          <a href="/signup" class="fc-save-btn">Create Free Account →</a>
          <a href="/login" class="fc-save-link">Already have an account? Sign in</a>
        </div>
        <% } else { %>
        <!-- Logged in: go to dashboard -->
        <div class="fc-save-panel fc-save-panel--done">
          <div class="fc-save-panel-icon">✅</div>
          <h3>Signed in as <%= locals.consumerName %></h3>
          <p>To permanently save this result to a profile and access it anytime, use your dashboard.</p>
          <a href="/dashboard" class="fc-save-btn">Go to My Dashboard →</a>
        </div>
        <% } %>

        <!-- Recalculate -->
        <div class="fc-recalc-card">
          <h4>Recalculate</h4>
          <p>Got an updated AMH value? Run the forecast again with new inputs.</p>
          <a href="/forecasting.asp" class="fc-recalc-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
            New Calculation
          </a>
        </div>

        <!-- Next steps -->
        <div class="fc-nextsteps-card">
          <h4>Suggested next steps</h4>
          <ul class="fc-nextsteps">
            <li>
              <span class="fc-ns-num">1</span>
              <span>Share this result with your gynaecologist at your next visit</span>
            </li>
            <li>
              <span class="fc-ns-num">2</span>
              <span>Retest AMH annually to track your ovarian reserve trend</span>
            </li>
            <li>
              <span class="fc-ns-num">3</span>
              <span>Ask about bone density screening if you are within 8 years of your forecast</span>
            </li>
          </ul>
        </div>

      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
