<%- include('partials/header', {
  pageTitle: 'Results',
  activeTab: 'results',
  userCount: locals.userCount || 0,
  orderCount: locals.orderCount || 0,
  resultCount: results.length,
  bmdCount: locals.bmdCount || 0
}) %>

<div class="adm-body">

  <div class="adm-stats">
    <div class="adm-stat">
      <div class="adm-stat-label">Total Results</div>
      <div class="adm-stat-value"><%= results.length %></div>
    </div>
  </div>

  <div class="adm-section-header">
    <h1 class="adm-section-title">Forecast Results</h1>
    <div class="adm-section-spacer"></div>
    <div class="adm-search">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="search-input" placeholder="Search name, email or profile…" oninput="filterTable()" autocomplete="off">
    </div>
    <a href="/admin/results?export=csv" class="adm-export">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </a>
  </div>

  <div class="adm-table-wrap">
    <table class="adm-table" id="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Consumer</th>
          <th>Profile</th>
          <th>Age at Test</th>
          <th>AMH (ng/mL)</th>
          <th>Cycle</th>
          <th>Forecast Age</th>
          <th class="hide-mobile">Test Date</th>
        </tr>
      </thead>
      <tbody>
        <% if (results.length === 0) { %>
          <tr><td colspan="8" class="adm-empty">No results yet.</td></tr>
        <% } %>
        <% results.forEach(function(r) { %>
        <tr>
          <td class="mono"><%= r.id %></td>
          <td>
            <strong><%= r.consumer_name || '—' %></strong><br>
            <span style="font-size:12px;color:#94A3B8;"><%= r.consumer_email %></span>
          </td>
          <td><%= r.profile_name || '—' %></td>
          <td><%= r.input_age || '—' %></td>
          <td><%= r.input_amh !== null && r.input_amh !== undefined ? parseFloat(r.input_amh).toFixed(2) : '—' %></td>
          <td>
            <% if (r.input_periods === 'Regular') { %>
              <span class="badge badge-blue">Regular</span>
            <% } else if (r.input_periods === 'Irregular') { %>
              <span class="badge badge-yellow">Irregular</span>
            <% } else { %>
              <span class="badge badge-grey"><%= r.input_periods || '—' %></span>
            <% } %>
          </td>
          <td><strong style="font-size:16px;color:var(--rose);"><%= r.forecast_age || '—' %></strong></td>
          <td class="mono hide-mobile"><%= r.created_at ? r.created_at.slice(0,16).replace('T',' ') : '—' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<script>
function filterTable() {
  var q = document.getElementById('search-input').value.toLowerCase();
  document.querySelectorAll('#data-table tbody tr').forEach(function(row) {
    row.style.display = row.textContent.toLowerCase().indexOf(q) > -1 ? '' : 'none';
  });
}
</script>

<%- include('partials/footer') %>
