<%- include('partials/header', {
  pageTitle: 'BMD Results',
  activeTab: 'bmd',
  userCount: locals.userCount || 0,
  orderCount: locals.orderCount || 0,
  resultCount: locals.resultCount || 0,
  bmdCount: records.length
}) %>

<div class="adm-body">

  <div class="adm-stats">
    <div class="adm-stat">
      <div class="adm-stat-label">Total BMD Tests</div>
      <div class="adm-stat-value"><%= records.length %></div>
    </div>
    <div class="adm-stat">
      <div class="adm-stat-label">Public (no login)</div>
      <div class="adm-stat-value"><%= records.filter(function(r){ return r.source !== 'clinic'; }).length %></div>
    </div>
    <div class="adm-stat">
      <div class="adm-stat-label">Legacy Clinic</div>
      <div class="adm-stat-value"><%= records.filter(function(r){ return r.source === 'clinic'; }).length %></div>
    </div>
  </div>

  <div class="adm-section-header">
    <h1 class="adm-section-title">BMD Results</h1>
    <div class="adm-section-spacer"></div>
    <div class="adm-search">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="search-input" placeholder="Search by name…" oninput="filterTable()" autocomplete="off">
    </div>
    <a href="/admin/bmd?export=csv" class="adm-export">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </a>
  </div>

  <div class="adm-table-wrap">
    <table class="adm-table" id="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Age</th>
          <th class="hide-mobile">Height (cm)</th>
          <th class="hide-mobile">Weight (kg)</th>
          <th>Classification</th>
          <th>Source</th>
          <th class="hide-mobile">Email</th>
          <th class="hide-mobile">Date</th>
        </tr>
      </thead>
      <tbody>
        <% if (records.length === 0) { %>
          <tr><td colspan="9" class="adm-empty">No BMD tests yet.</td></tr>
        <% } %>
        <% records.forEach(function(r) { %>
        <%
          const badgeClass = r.classification === 'Normal' ? 'badge-green'
            : r.classification === 'Osteopenia' ? 'badge-yellow'
            : r.classification === 'Osteoporosis' ? 'badge-red'
            : 'badge-grey';
        %>
        <tr>
          <td class="mono"><%= r.id %></td>
          <td><strong><%= r.name || '—' %></strong></td>
          <td><%= r.age || '—' %></td>
          <td class="hide-mobile"><%= r.height || '—' %></td>
          <td class="hide-mobile"><%= r.weight || '—' %></td>
          <td><span class="badge <%= badgeClass %>"><%= r.classification || '—' %></span></td>
          <td>
            <% if (r.source === 'clinic') { %>
              <span class="badge badge-grey">Legacy Clinic<% if (r.clinic_username) { %> · <%= r.clinic_username %><% } %></span>
            <% } else { %>
              <span class="badge badge-blue">Public</span>
            <% } %>
          </td>
          <td class="hide-mobile"><%= r.email || '—' %></td>
          <td class="mono hide-mobile"><%= r.created_at ? r.created_at.slice(0,16).replace('T',' ') : '—' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

</div>

<script>
function filterTable() {
  var q = document.getElementById('search-input').value.toLowerCase();
  document.querySelectorAll('#data-table tbody tr').forEach(function(row) {
    row.style.display = row.textContent.toLowerCase().indexOf(q) > -1 ? '' : 'none';
  });
}
</script>

<%- include('partials/footer') %>
