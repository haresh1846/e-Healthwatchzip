<%- include('partials/header', {
  pageTitle: 'Clinic Accounts',
  activeTab: 'clinic',
  userCount:   locals.userCount   || 0,
  orderCount:  locals.orderCount  || 0,
  resultCount: locals.resultCount || 0,
  bmdCount:    locals.bmdCount    || 0,
  clinicCount: accounts.length
}) %>

<div class="adm-body">

  <% if (hasDefaultCredentials) { %>
  <div style="background:#FEF9C3;border:1.5px solid #FDE68A;border-radius:12px;padding:16px 20px;margin-bottom:24px;display:flex;align-items:flex-start;gap:12px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#92400E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
    <div>
      <strong style="color:#92400E;font-size:14px;">Default credentials still active</strong>
      <p style="color:#78350F;font-size:13px;margin:4px 0 0;">The <code style="background:#FEF3C7;padding:1px 5px;border-radius:4px;">admin</code> account is still using the default password <code style="background:#FEF3C7;padding:1px 5px;border-radius:4px;">admin123</code>. Anyone who knows this can access all patient BMD data. Change it now using the form below.</p>
    </div>
  </div>
  <% } %>

  <% if (locals.flash) { %>
  <div style="background:<%= flash.type === 'success' ? '#DCFCE7' : '#FFE4E6' %>;border:1.5px solid <%= flash.type === 'success' ? '#BBF7D0' : '#FECDD3' %>;border-radius:10px;padding:12px 18px;margin-bottom:20px;font-size:14px;color:<%= flash.type === 'success' ? '#15803D' : '#9F1239' %>;">
    <%= flash.message %>
  </div>
  <% } %>

  <div class="adm-section-header">
    <h1 class="adm-section-title">Clinic Accounts</h1>
    <div class="adm-section-spacer"></div>
  </div>

  <% accounts.forEach(function(account) { %>
  <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);margin-bottom:20px;overflow:hidden;">

    <!-- Account header -->
    <div style="padding:18px 20px;border-bottom:1px solid #F1F5F9;display:flex;align-items:center;gap:14px;flex-wrap:wrap;">
      <div style="background:#1E293B;color:#fff;border-radius:9px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;flex-shrink:0;">
        <%= account.username.charAt(0).toUpperCase() %>
      </div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:16px;font-weight:800;color:#0F172A;"><%= account.username %></div>
        <div style="font-size:12px;color:#94A3B8;margin-top:2px;">
          Expires: <strong><%= account.expirydate || 'never' %></strong>
          &nbsp;·&nbsp;
          Scans remaining: <strong><%= account.limitavailable %></strong>
        </div>
      </div>
      <%
        const today = new Date().toISOString().slice(0,10);
        const expired = account.expirydate && account.expirydate < today;
      %>
      <% if (expired) { %>
        <span class="badge badge-red">Expired</span>
      <% } else { %>
        <span class="badge badge-green">Active</span>
      <% } %>
      <% if (account.isDefault) { %>
        <span class="badge badge-yellow">⚠ Default password</span>
      <% } %>
    </div>

    <!-- Two-column edit forms -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;">

      <!-- Change password -->
      <div style="padding:20px;border-right:1px solid #F1F5F9;">
        <div style="font-size:13px;font-weight:700;color:#0F172A;margin-bottom:12px;display:flex;align-items:center;gap:6px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Change Password
        </div>
        <form method="POST" action="/admin/clinic/<%= encodeURIComponent(account.username) %>/password" style="display:flex;gap:8px;flex-wrap:wrap;">
          <input type="password" name="new_password" placeholder="New password"
            style="flex:1;min-width:140px;padding:9px 12px;border:1.5px solid #E2E8F0;border-radius:8px;font-family:var(--font-sans);font-size:13px;outline:none;"
            required minlength="4" autocomplete="new-password">
          <button type="submit"
            style="padding:9px 16px;background:var(--rose);color:#fff;border:none;border-radius:8px;font-family:var(--font-sans);font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;">
            Update
          </button>
        </form>
        <p style="font-size:11px;color:#94A3B8;margin-top:8px;">Minimum 4 characters. Stored as plain text (clinic system limitation).</p>
      </div>

      <!-- Edit expiry and scan limit -->
      <div style="padding:20px;">
        <div style="font-size:13px;font-weight:700;color:#0F172A;margin-bottom:12px;display:flex;align-items:center;gap:6px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Expiry & Scan Limit
        </div>
        <form method="POST" action="/admin/clinic/<%= encodeURIComponent(account.username) %>/settings" style="display:flex;gap:8px;flex-wrap:wrap;align-items:flex-end;">
          <div style="flex:1;min-width:120px;">
            <label style="font-size:11px;font-weight:600;color:#64748B;display:block;margin-bottom:4px;">Expiry Date</label>
            <input type="date" name="expirydate" value="<%= account.expirydate || '' %>"
              style="width:100%;padding:9px 12px;border:1.5px solid #E2E8F0;border-radius:8px;font-family:var(--font-sans);font-size:13px;outline:none;">
          </div>
          <div style="flex:1;min-width:100px;">
            <label style="font-size:11px;font-weight:600;color:#64748B;display:block;margin-bottom:4px;">Scans Remaining</label>
            <input type="number" name="limitavailable" value="<%= account.limitavailable %>" min="0" step="1"
              style="width:100%;padding:9px 12px;border:1.5px solid #E2E8F0;border-radius:8px;font-family:var(--font-sans);font-size:13px;outline:none;"
              required>
          </div>
          <button type="submit"
            style="padding:9px 16px;background:#1E293B;color:#fff;border:none;border-radius:8px;font-family:var(--font-sans);font-size:13px;font-weight:700;cursor:pointer;white-space:nowrap;margin-bottom:0;">
            Save
          </button>
        </form>
      </div>

    </div>
  </div>
  <% }); %>

  <% if (accounts.length === 0) { %>
  <div class="adm-table-wrap">
    <p class="adm-empty">No clinic accounts found.</p>
  </div>
  <% } %>

</div>

<%- include('partials/footer') %>
