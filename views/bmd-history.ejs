<%- include('partials/header') %>

<!------ Banner ------->
<section id="banner-section">
  <div class="container-fluid">
    <div class="row">
      <div class="banner-placeholder text-center">
        <h2><%= patientFilter ? 'Patient: ' + patientFilter : 'BMD History' %></h2>
      </div>
    </div>
  </div>
</section>

<!------ History Content ------->
<section id="about-cont">
  <div class="container">
    <div class="row">
      <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">

        <!-- Breadcrumb / actions bar -->
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:24px;">
          <a href="/bmd.asp" style="display:inline-flex;align-items:center;gap:6px;background:var(--rose);color:#fff;padding:9px 18px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Calculation
          </a>
          <% if (patientFilter) { %>
          <a href="/bmd-history" style="display:inline-flex;align-items:center;gap:6px;background:#F1F5F9;color:#334155;padding:9px 18px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            All Records
          </a>
          <% } %>
          <span style="margin-left:auto;font-size:13px;color:#94A3B8;"><%= records.length %> record<%= records.length === 1 ? '' : 's' %></span>
        </div>

        <% if (records.length === 0) { %>
        <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);padding:60px 20px;text-align:center;">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#CBD5E1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:16px"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
          <p style="font-size:16px;color:#94A3B8;margin:0;">
            <% if (patientFilter) { %>No records found for "<strong><%= patientFilter %></strong>".<% } else { %>No calculations yet. Run your first BMD calculation to see history here.<% } %>
          </p>
        </div>
        <% } else { %>

        <!-- Records table -->
        <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);overflow:hidden;">
          <table style="width:100%;border-collapse:collapse;">
            <thead>
              <tr style="background:#F8FAFC;">
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;">Patient</th>
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;" class="hide-mobile">Age</th>
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;" class="hide-mobile">Height&nbsp;(cm)</th>
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;" class="hide-mobile">Weight&nbsp;(kg)</th>
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;">BMD Score</th>
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;" class="hide-mobile">Date</th>
                <th style="padding:12px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;"></th>
              </tr>
            </thead>
            <tbody>
              <% records.forEach(function(r) {
                // Recompute result for display
                const h = parseFloat(r.height), w = parseFloat(r.weight);
                const a = parseFloat(r.age), hal = parseFloat(r.hal), nsa = parseFloat(r.nsa);
                let score = '—';
                if (![h,w,a,hal,nsa].some(isNaN)) {
                  score = (1.06861 * Math.pow(h*0.01,0.326842) * Math.pow(w,0.211909) *
                           Math.pow(hal,0.0608258) * Math.pow(a,-0.332916) *
                           Math.pow(nsa*0.0174533,-0.239446)).toFixed(4);
                }
                const dateStr = r.created_at ? r.created_at.slice(0,10) : '—';
              %>
              <tr style="border-bottom:1px solid #F1F5F9;">
                <td style="padding:13px 16px;font-size:14px;color:#0F172A;font-weight:600;">
                  <%= r.name %>
                </td>
                <td style="padding:13px 16px;font-size:14px;color:#334155;" class="hide-mobile"><%= r.age %></td>
                <td style="padding:13px 16px;font-size:14px;color:#334155;" class="hide-mobile"><%= r.height %></td>
                <td style="padding:13px 16px;font-size:14px;color:#334155;" class="hide-mobile"><%= r.weight %></td>
                <td style="padding:13px 16px;">
                  <span style="font-size:15px;font-weight:800;color:#0F172A;font-family:monospace;"><%= score %></span>
                </td>
                <td style="padding:13px 16px;font-size:13px;color:#64748B;" class="hide-mobile"><%= dateStr %></td>
                <td style="padding:13px 16px;">
                  <a href="/bmd-patient/<%= encodeURIComponent(r.name) %>"
                     style="font-size:12px;font-weight:700;color:var(--rose);text-decoration:none;white-space:nowrap;">
                    All for patient →
                  </a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
        <% } %>

      </div>
    </div>
  </div>
</section>

<style>
@media (max-width: 700px) { .hide-mobile { display: none !important; } }
</style>

<%- include('partials/footer') %>
