<%- include('partials/header', { pageTitle: 'Forgot Password — e-healthwatch' }) %>

<div class="auth-bg">
  <div class="auth-wrap auth-wrap--narrow">

    <div class="auth-card">
      <a href="/" class="auth-brand">
        <div class="auth-brand-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <span>e-health<strong>watch</strong></span>
      </a>

      <h1 class="auth-title">Forgot your password?</h1>

      <% if (sent) { %>
        <p class="auth-sub">If an account exists with that email address, we've sent a password reset link. It's valid for 1 hour — check your inbox.</p>
        <p class="auth-switch" style="margin-top:20px;"><a href="/login">&larr; Back to sign in</a></p>
      <% } else { %>
        <p class="auth-sub">Enter your account email and we'll send you a link to set a new password.</p>

        <form method="POST" action="/forgot-password" class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="auth-field">
            <label for="email">Email address</label>
            <input type="email" id="email" name="email" required placeholder="you@example.com" class="form-control" autocomplete="email">
          </div>
          <button type="submit" class="auth-submit">Send reset link
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </form>

        <p class="auth-switch">Remembered it after all? <a href="/login">Sign in</a></p>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
