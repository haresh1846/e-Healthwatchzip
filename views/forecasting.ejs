<%- include('partials/header', {
  pageTitle: 'Menopause Forecasting — e-healthwatch',
  pageDesc:  'Predict your age of natural menopause using your AMH blood test value, age, and cycle regularity. Free to use.'
}) %>

<!-- ═══════════════════════ HERO BANNER ════════════════════════════ -->
<section class="fc-hero">
  <div class="fc-hero__inner">
    <div class="fc-hero__text">
      <div class="ehw-sec__label">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Predictive Health Tool
      </div>
      <h1 class="fc-hero__h1">Menopause Forecasting</h1>
      <p class="fc-hero__sub">Enter your AMH blood test value to estimate your natural menopause age using evidence-based mathematical modelling.</p>
      <div class="fc-hero__pills">
        <span class="fc-pill">🩸 AMH-based</span>
        <span class="fc-pill">📊 Validated model</span>
        <span class="fc-pill">⚡ Instant result</span>
        <span class="fc-pill">🔬 Free to use</span>
      </div>
    </div>
    <div class="fc-hero__img-wrap">
      <img src="/images/forecast-illustration.jpg" alt="Menopause forecasting illustration" class="fc-hero__img" id="fc-illus"
        onerror="this.style.display='none'">
    </div>
  </div>
</section>

<!-- ═══════════════════════ MAIN CONTENT ══════════════════════════ -->
<div class="fc-body">
  <div class="fc-split">

    <!-- ─── LEFT: Form ──────────────────────────────────────────── -->
    <div class="fc-form-col">
      <div class="fc-form-card">
        <div class="fc-form-header">
          <div class="fc-form-header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div>
            <h2 class="fc-form-title">Calculate your forecast</h2>
            <p class="fc-form-sub">Takes under 60 seconds</p>
          </div>
        </div>

        <form name="frm_salableitems" id="fc-form" method="post" action="/mpresult.asp" novalidate>

          <!-- Name -->
          <div class="fc-field">
            <label for="Txt_name">Your name <span class="fc-required">*</span></label>
            <input type="text" id="Txt_name" name="Txt_name" class="form-control" placeholder="e.g. Priya" maxlength="50" autocomplete="given-name">
          </div>

          <!-- Age + Periods side by side -->
          <div class="fc-row-2">
            <div class="fc-field">
              <label for="Txt_age">Current age <span class="fc-required">*</span></label>
              <input type="number" id="Txt_age" name="Txt_age" class="form-control" placeholder="e.g. 36" min="18" max="60" maxlength="2">
              <span class="fc-field-hint">Years (18–60)</span>
            </div>
            <div class="fc-field">
              <label for="cmbperiods">Menstrual cycle <span class="fc-required">*</span></label>
              <select id="cmbperiods" name="cmbperiods" class="form-control">
                <option value="R">Regular (21–35 days)</option>
                <option value="I">Irregular</option>
              </select>
            </div>
          </div>

          <!-- AMH -->
          <div class="fc-field">
            <label for="Txt_amh">
              AMH value (ng/mL) <span class="fc-required">*</span>
              <button type="button" class="fc-info-toggle" onclick="toggleAmhInfo()" aria-label="What is AMH?">What is AMH?</button>
            </label>
            <input type="number" id="Txt_amh" name="Txt_amh" class="form-control" placeholder="e.g. 2.50" step="0.01" min="0.01" max="15">
            <span class="fc-field-hint">Normal range: 0.9–9.5 ng/mL · Valid input: 0.5–6.00</span>
          </div>

          <!-- AMH converter (toggle) -->
          <div class="fc-converter" id="amh-info-box" style="display:none;">
            <div class="fc-converter-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Unit converter: pmol/L → ng/mL
            </div>
            <div class="fc-converter-row">
              <input type="number" id="pmol_input" class="form-control" placeholder="Enter pmol/L" step="0.1" oninput="convertPmol()">
              <span class="fc-converter-eq">=</span>
              <input type="number" id="ngml_output" class="form-control" placeholder="ng/mL result" readonly style="background:var(--stone-50);">
              <button type="button" class="fc-converter-copy" onclick="useConvertedValue()">Use →</button>
            </div>
            <p class="fc-converter-note">Divide pmol/L by 7.14 to get ng/mL</p>
          </div>

          <!-- AMH range visual -->
          <div class="fc-range-card">
            <div class="fc-range-title">AMH reference ranges by age</div>
            <div class="fc-range-rows">
              <div class="fc-range-row"><span class="fc-range-age">25–29</span><div class="fc-range-bar"><div class="fc-range-fill" style="width:90%"></div></div><span class="fc-range-val">3.0–6.8</span></div>
              <div class="fc-range-row"><span class="fc-range-age">30–34</span><div class="fc-range-bar"><div class="fc-range-fill" style="width:72%"></div></div><span class="fc-range-val">2.2–4.8</span></div>
              <div class="fc-range-row"><span class="fc-range-age">35–39</span><div class="fc-range-bar"><div class="fc-range-fill" style="width:52%"></div></div><span class="fc-range-val">1.2–3.5</span></div>
              <div class="fc-range-row"><span class="fc-range-age">40–44</span><div class="fc-range-bar"><div class="fc-range-fill" style="width:32%"></div></div><span class="fc-range-val">0.5–2.1</span></div>
              <div class="fc-range-row"><span class="fc-range-age">45–50</span><div class="fc-range-bar"><div class="fc-range-fill" style="width:14%"></div></div><span class="fc-range-val">0.1–0.9</span></div>
            </div>
            <p class="fc-range-note">Values in ng/mL · Source: ACOG Clinical Guidelines</p>
          </div>

          <!-- Disclaimer -->
          <div class="fc-disclaimer">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>This is a <strong>predictive estimate</strong>, not a clinical diagnosis. Always consult your gynaecologist for medical advice.</span>
          </div>

          <!-- Buttons -->
          <div class="fc-actions">
            <button type="button" onclick="calcfm()" class="fc-btn-calc">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              Calculate My Forecast
            </button>
            <button type="button" onclick="clearall()" class="fc-btn-reset">Reset</button>
          </div>

          <!-- Save result CTA -->
          <% if (!locals.consumerId) { %>
          <div class="fc-save-cta">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <span>Want to save your result? <a href="/signup">Create a free account →</a> Pay ₹49 once — view your result anytime.</span>
          </div>
          <% } else { %>
          <div class="fc-save-cta fc-save-cta--logged">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            <span>Signed in as <strong><%= locals.consumerName %></strong> · <a href="/dashboard">Save to your dashboard (₹49) →</a></span>
          </div>
          <% } %>

        </form>
      </div>
    </div>

    <!-- ─── RIGHT: Info panel ────────────────────────────────────── -->
    <div class="fc-info-col">

      <!-- What is AMH -->
      <div class="fc-info-card">
        <div class="fc-info-card-icon fc-info-icon--rose">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h3>What is AMH?</h3>
        <p>Anti-Müllerian Hormone (AMH) is produced by the small follicles in your ovaries. Its level directly reflects your <strong>ovarian reserve</strong> — the number of eggs remaining — making it the most accurate single biomarker for predicting when menopause will occur.</p>
        <p>Unlike FSH, AMH remains stable throughout your menstrual cycle, so it can be tested on <em>any</em> day of the month.</p>
      </div>

      <!-- Where to get tested -->
      <div class="fc-info-card">
        <div class="fc-info-card-icon fc-info-icon--amber">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3>Where to get AMH tested</h3>
        <ul class="fc-lab-list">
          <li><span class="fc-lab-dot fc-lab-dot--rose"></span>SRL Diagnostics</li>
          <li><span class="fc-lab-dot fc-lab-dot--amber"></span>Dr Lal PathLabs</li>
          <li><span class="fc-lab-dot fc-lab-dot--green"></span>Metropolis Healthcare</li>
          <li><span class="fc-lab-dot fc-lab-dot--purple"></span>Thyrocare</li>
          <li><span class="fc-lab-dot fc-lab-dot--rose"></span>Any NABL-accredited lab</li>
        </ul>
        <div class="fc-lab-note">
          No doctor's prescription required · Results in 24–48 hrs · Typically ₹800–₹1,500
        </div>
      </div>

      <!-- How the model works -->
      <div class="fc-info-card">
        <div class="fc-info-card-icon fc-info-icon--green">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        </div>
        <h3>How the model works</h3>
        <p>The forecasting model uses a <strong>power regression equation</strong> calibrated on large longitudinal cohort studies. AMH has a non-linear relationship with time-to-menopause: a small drop at lower values predicts a proportionally larger effect on timing.</p>
        <div class="fc-model-params">
          <div class="fc-model-param">
            <span class="fc-model-label">Regular cycles</span>
            <span class="fc-model-eq">FM = 35.49 × AMH<sup>0.15</sup></span>
          </div>
          <div class="fc-model-param">
            <span class="fc-model-label">Irregular cycles</span>
            <span class="fc-model-eq">FM = 41.41 × AMH<sup>0.17</sup></span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
function clearall() {
  document.getElementById('fc-form').reset();
  document.getElementById('Txt_name').focus();
}

function toggleAmhInfo() {
  var box = document.getElementById('amh-info-box');
  box.style.display = box.style.display === 'none' ? 'block' : 'none';
}

function convertPmol() {
  var pmol = parseFloat(document.getElementById('pmol_input').value);
  document.getElementById('ngml_output').value = isNaN(pmol) ? '' : (pmol / 7.14).toFixed(2);
}

function useConvertedValue() {
  var val = document.getElementById('ngml_output').value;
  if (val) {
    document.getElementById('Txt_amh').value = val;
    document.getElementById('amh-info-box').style.display = 'none';
  }
}

function calcfm() {
  var form = document.getElementById('fc-form');
  var name = form.Txt_name.value.trim();
  var age  = form.Txt_age.value.trim();
  var amh  = form.Txt_amh.value.trim();

  if (!name) { showError('Txt_name', 'Please enter your name'); return; }
  if (!age || isNaN(age) || age < 18 || age > 60) { showError('Txt_age', 'Please enter a valid age between 18 and 60'); return; }
  if (!amh || isNaN(amh)) { showError('Txt_amh', 'Please enter your AMH value'); return; }
  var amhVal = parseFloat(amh);
  if (amhVal < 0.5 || amhVal > 6) { showError('Txt_amh', 'AMH value must be between 0.5 and 6.00 ng/mL'); return; }

  clearErrors();
  form.method = 'post';
  form.action = '/mpresult.asp';
  form.submit();
}

function showError(fieldId, msg) {
  clearErrors();
  var field = document.getElementById(fieldId);
  field.classList.add('fc-field-error');
  var err = document.createElement('span');
  err.className = 'fc-error-msg';
  err.textContent = msg;
  field.parentNode.appendChild(err);
  field.focus();
}

function clearErrors() {
  document.querySelectorAll('.fc-field-error').forEach(function(el) { el.classList.remove('fc-field-error'); });
  document.querySelectorAll('.fc-error-msg').forEach(function(el) { el.remove(); });
}
</script>

<%- include('partials/footer') %>
