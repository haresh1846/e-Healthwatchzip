<%- include('partials/header') %>

<script>
function clearall() {
  window.location = '/forecasting.asp';
}

function calcfm() {
  if (document.frm_salableitems.Txt_name.value === '') {
    alert('Name should not be empty');
    document.frm_salableitems.Txt_name.focus();
    return false;
  }
  if (document.frm_salableitems.Txt_age.value === '') {
    alert('Age should not be empty');
    document.frm_salableitems.Txt_age.focus();
    return false;
  }
  if (document.frm_salableitems.Txt_amh.value === '') {
    alert('AMH should not be empty');
    document.frm_salableitems.Txt_amh.focus();
    return false;
  }
  var amh = parseFloat(document.frm_salableitems.Txt_amh.value);
  if (amh < 0.5 || amh > 6) {
    alert('Invalid AMH value');
    document.frm_salableitems.Txt_amh.value = '';
    document.frm_salableitems.Txt_amh.focus();
    return false;
  }
  document.frm_salableitems.method = 'post';
  document.frm_salableitems.action = '/mpresult.asp';
  document.frm_salableitems.submit();
}
</script>

<!------ About Banner ------->
<section id="banner-section">
  <div class="container-fluid">
    <div class="row">
      <div class="banner-placeholder text-center">
        <h2>Menopause Forecasting</h2>
      </div>
    </div>
  </div>
</section>

<!------ Forecasting Form ------->
<section id="about-cont">
  <div class="container">
    <div class="row">
      <form name="frm_salableitems" method="post" action="/mpresult.asp">
        <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
          <h2 class="aboutpage-title">Menopause Forecasting</h2>
          <h4><font color="red">Note: Menopause calculator is only for your guidance. Please consult your physician for further diagnosis and treatment.<br><br>
          AMH unit: ng/ml. Range is from 0.5–6.00<br></font></h4>
          <div class="aboutpage-content">
            <div class="form-group inner-tittle">
              <label class="inner-tittle">Name <span class="red-star">*</span></label>
              <input type="text" class="form-control" id="Txt_name" placeholder="Name" name="Txt_name" maxlength="50">
            </div>
            <div class="form-group inner-tittle">
              <label class="inner-tittle">Age <span class="red-star">*</span></label>
              <input type="text" class="form-control" id="Txt_age" placeholder="Age" name="Txt_age" maxlength="2">
            </div>
            <div class="form-group inner-tittle">
              <label class="inner-tittle">Periods <span class="red-star">*</span></label>
              <select name="cmbperiods" class="form-control">
                <option value="R">Regular</option>
                <option value="I">Irregular</option>
              </select>
            </div>
            <div class="form-group inner-tittle">
              <label class="inner-tittle">AMH <span class="red-star">*</span></label>
              <input type="text" class="form-control" id="Txt_amh" placeholder="AMH" name="Txt_amh" maxlength="4">
            </div>
            <button type="button" name="btn_enq" id="btn_enq" class="btn btn-success" onclick="calcfm()">Calculate</button>
            <button type="button" name="btn_reset" id="btn_reset" class="btn btn-warning" onclick="clearall()">Reset</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
