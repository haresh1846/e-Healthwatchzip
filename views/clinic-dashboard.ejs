<%- include('partials/header') %>

<!------ Banner ------->
<section id="banner-section">
  <div class="container-fluid">
    <div class="row">
      <div class="banner-placeholder text-center">
        <h2>Clinic Dashboard</h2>
      </div>
    </div>
  </div>
</section>

<section id="about-cont">
  <div class="container">

    <!-- Welcome + logout -->
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:28px;padding-top:8px;">
      <div>
        <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#94A3B8;margin-bottom:4px;">Signed in as</div>
        <h2 style="font-family:var(--font-sans);font-size:22px;font-weight:800;color:#0F172A;margin:0;"><%= account.username %></h2>
      </div>
      <a href="/bmdlogout" style="display:inline-flex;align-items:center;gap:6px;background:#F1F5F9;color:#334155;padding:8px 16px;border-radius:8px;font-weight:700;font-size:13px;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Log out
      </a>
    </div>

    <!-- Expiry warning banner -->
    <% if (expiryWarning) { %>
    <div style="background:#FEF9C3;border:1.5px solid #FDE68A;border-radius:12px;padding:14px 20px;margin-bottom:24px;display:flex;align-items:center;gap:12px;">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#92400E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      <span style="color:#78350F;font-size:14px;font-weight:600;">Account expiry is approaching (<strong><%= expiryLabel %></strong>). Contact the administrator to renew.</span>
    </div>
    <% } %>

    <!-- Stat cards -->
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px;">

      <!-- Scans used -->
      <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);padding:22px 24px;">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#94A3B8;margin-bottom:8px;">Scans Used</div>
        <div style="font-size:36px;font-weight:900;color:#0F172A;font-family:var(--font-sans);line-height:1;"><%= scansUsed %></div>
      </div>

      <!-- Scans remaining -->
      <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);padding:22px 24px;">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#94A3B8;margin-bottom:8px;">Scans Remaining</div>
        <div style="font-size:36px;font-weight:900;color:<%= account.limitavailable > 0 ? '#15803D' : '#9F1239' %>;font-family:var(--font-sans);line-height:1;"><%= account.limitavailable %></div>
      </div>

      <!-- Expiry -->
      <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);padding:22px 24px;">
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#94A3B8;margin-bottom:8px;">Account Expiry</div>
        <div style="font-size:20px;font-weight:800;color:<%= expiryWarning ? '#B45309' : '#0F172A' %>;font-family:var(--font-sans);line-height:1.2;margin-top:4px;"><%= expiryLabel %></div>
      </div>
    </div>

    <!-- Action buttons -->
    <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px;">
      <a href="/bmd.asp" style="display:inline-flex;align-items:center;gap:8px;background:var(--rose);color:#fff;padding:13px 24px;border-radius:10px;font-weight:700;font-size:15px;text-decoration:none;box-shadow:0 4px 14px rgba(225,29,72,.25);">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New BMD Calculation
      </a>
      <a href="/bmd-history" style="display:inline-flex;align-items:center;gap:8px;background:#F1F5F9;color:#334155;padding:13px 24px;border-radius:10px;font-weight:700;font-size:15px;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
        View All History
      </a>
    </div>

    <!-- Recent patients -->
    <div style="background:#fff;border-radius:14px;box-shadow:0 1px 4px rgba(0,0,0,.07);overflow:hidden;">
      <div style="padding:18px 20px;border-bottom:1px solid #F1F5F9;display:flex;align-items:center;justify-content:space-between;">
        <h3 style="font-family:var(--font-sans);font-size:16px;font-weight:800;color:#0F172A;margin:0;">Recent Patients</h3>
        <% if (recent.length > 0) { %>
        <a href="/bmd-history" style="font-size:13px;font-weight:700;color:var(--rose);text-decoration:none;">View all →</a>
        <% } %>
      </div>

      <% if (recent.length === 0) { %>
      <div style="padding:48px 20px;text-align:center;color:#94A3B8;font-size:15px;">
        No calculations yet. Run your first BMD calculation to see activity here.
      </div>
      <% } else { %>
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:#F8FAFC;">
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;">Patient</th>
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;">BMD Score</th>
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;">Classification</th>
            <th style="padding:10px 16px;text-align:left;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#64748B;border-bottom:1px solid #E2E8F0;">Date</th>
          </tr>
        </thead>
        <tbody>
          <% recent.forEach(function(r) {
            const s = parseFloat(r.score);
            let cls = '—', clsColor = '#94A3B8', clsBg = '#F1F5F9';
            if (!isNaN(s)) {
              if (s >= 0.738)      { cls = 'Normal';       clsColor = '#15803D'; clsBg = '#DCFCE7'; }
              else if (s >= 0.558) { cls = 'Osteopenia';   clsColor = '#92400E'; clsBg = '#FEF3C7'; }
              else                 { cls = 'Osteoporosis'; clsColor = '#9F1239'; clsBg = '#FFE4E6'; }
            }
          %>
          <tr style="border-bottom:1px solid #F1F5F9;">
            <td style="padding:12px 16px;font-size:14px;font-weight:600;color:#0F172A;">
              <a href="/bmd-patient/<%= encodeURIComponent(r.name) %>" style="color:inherit;text-decoration:none;"><%= r.name %></a>
            </td>
            <td style="padding:12px 16px;font-size:14px;font-family:monospace;font-weight:700;color:#0F172A;"><%= r.score || '—' %></td>
            <td style="padding:12px 16px;">
              <span style="background:<%= clsBg %>;color:<%= clsColor %>;padding:3px 10px;border-radius:9999px;font-size:12px;font-weight:700;"><%= cls %></span>
            </td>
            <td style="padding:12px 16px;font-size:13px;color:#64748B;"><%= r.dateStr %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
      <% } %>
    </div>

  </div>
</section>

<style>
@media (max-width: 600px) {
  section#about-cont .container > div:first-child { flex-direction: column; align-items: flex-start; }
  section#about-cont > .container > div[style*="grid-template-columns:repeat(3"] { grid-template-columns: 1fr !important; }
}
</style>

<%- include('partials/footer') %>
