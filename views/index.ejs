<!-- ═══════════════════════════════════════════════════════════
     CONTACT SECTION
════════════════════════════════════════════════════════════════ -->
<section class="ehw-sec ehw-sec--cream">
  <div class="ehw-sec__inner">
    <div class="ehw-sec__head">
      <h2>Let's start a conversation</h2>
      <p>Have questions about our predictive models or need support? We're here for you.</p>
    </div>
    <div class="ehw-contact__card">
      <!-- Info -->
      <div class="ehw-contact__info">
        <h3>Contact Info</h3>
        <div class="ehw-contact__info-item">
          <div class="ehw-contact__info-ico">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p class="ehw-contact__info-label">Email us</p>
            <p class="ehw-contact__info-value">hello@e-healthwatch.com</p>
          </div>
        </div>
        <div class="ehw-contact__info-item">
          <div class="ehw-contact__info-ico">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <p class="ehw-contact__info-label">Call us</p>
            <p class="ehw-contact__info-value">+44 (0) 123 456 789</p>
          </div>
        </div>
        <div class="ehw-contact__info-item">
          <div class="ehw-contact__info-ico">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p class="ehw-contact__info-label">Location</p>
            <p class="ehw-contact__info-value">Medical Research Park<br>London, UK</p>
          </div>
        </div>
      </div>
      <!-- Form -->
      <form method="post" action="/">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="validate1" value="T">
        <div class="ehw-contact__row">
          <div>
            <label for="c-fname">First Name</label>
            <input id="c-fname" type="text" name="fname" class="ehw-contact__input" placeholder="Jane">
          </div>
          <div>
            <label for="c-lname">Last Name</label>
            <input id="c-lname" type="text" name="lname" class="ehw-contact__input" placeholder="Doe">
          </div>
        </div>
        <label for="c-email">Email Address</label>
        <input id="c-email" type="email" name="email" class="ehw-contact__input" placeholder="jane@example.com">
        <label for="c-phone">Phone</label>
        <input id="c-phone" type="text" name="phone" class="ehw-contact__input" placeholder="+91 98765 43210">
        <label for="c-msg">Message</label>
        <textarea id="c-msg" name="comment" class="ehw-contact__input" placeholder="How can we help you?"></textarea>
        <% if (locals.contactSuccess) { %>
          <p style="color:var(--green-600);font-weight:700;margin-bottom:14px">&#10003; Message sent! We'll be in touch soon.</p>
        <% } %>
        <button type="submit" class="ehw-contact__submit">Send Message</button>
      </form>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
