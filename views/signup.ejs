<%- include('partials/header', { pageTitle: 'Create Account — e-healthwatch', pageDesc: 'Create your free e-healthwatch account and start forecasting your menopause timeline.' }) %>

<div class="auth-bg">
  <div class="auth-wrap">

    <!-- Form card -->
    <div class="auth-card">
      <a href="/" class="auth-brand">
        <div class="auth-brand-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <span>e-health<strong>watch</strong></span>
      </a>

      <h1 class="auth-title">Create your free account</h1>
      <p class="auth-sub">Join 12,000+ women taking control of their health</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-alert"><%= error %></div>
      <% } %>

      <form method="POST" action="/signup" class="auth-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="auth-field">
          <label for="full_name">Full name</label>
          <input type="text" id="full_name" name="full_name" required placeholder="Your name" class="form-control" autocomplete="name">
        </div>
        <div class="auth-field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" class="form-control" autocomplete="email">
        </div>
        <div class="auth-row-2">
          <div class="auth-field">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" required placeholder="Min. 8 characters" class="form-control" autocomplete="new-password">
          </div>
          <div class="auth-field">
            <label for="confirm_password">Confirm password</label>
            <input type="password" id="confirm_password" name="confirm_password" required placeholder="Repeat password" class="form-control" autocomplete="new-password">
          </div>
        </div>
        <div class="auth-consent">
          <input type="checkbox" id="consent" name="consent" required>
          <label for="consent">I agree to the <a href="/privacy" target="_blank">Privacy Policy</a> and consent to collection and processing of my health data <em>(DPDP Act, 2023)</em>.</label>
        </div>
        <button type="submit" class="auth-submit">Create Free Account
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>

      <p class="auth-switch">Already have an account? <a href="/login">Sign in here</a></p>
    </div>

    <!-- Info panel -->
    <div class="auth-panel">
      <div class="auth-panel-inner">
        <h3>Your health journey, personalised</h3>
        <ul class="auth-features">
          <li>
            <span class="auth-feat-icon auth-feat-rose">🌸</span>
            <div>
              <strong>Menopause Forecast</strong>
              <p>Know your estimated age of menopause from your AMH blood test result</p>
            </div>
          </li>
          <li>
            <span class="auth-feat-icon auth-feat-amber">👨‍👩‍👧</span>
            <div>
              <strong>Up to 3 profiles</strong>
              <p>Track health insights for yourself, your mother, or your sister</p>
            </div>
          </li>
          <li>
            <span class="auth-feat-icon auth-feat-green">🔒</span>
            <div>
              <strong>Results stored forever</strong>
              <p>Pay once — ₹49. Revisit your result any time, always free</p>
            </div>
          </li>
        </ul>
        <div class="auth-price-badge">
          <div>
            <div class="auth-price-label">One-time test fee</div>
            <div class="auth-price-row"><span class="auth-price-amt">₹49</span><del>₹199</del><span class="auth-discount">75% off</span></div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
