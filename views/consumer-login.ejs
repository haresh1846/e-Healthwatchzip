<%- include('partials/header', { pageTitle: 'Sign In — e-healthwatch', pageDesc: 'Sign in to your e-healthwatch account to view your menopause forecast and health profiles.' }) %>

<div class="auth-bg">
  <div class="auth-wrap auth-wrap--narrow">

    <div class="auth-card">
      <a href="/" class="auth-brand">
        <div class="auth-brand-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <span>e-health<strong>watch</strong></span>
      </a>

      <h1 class="auth-title">Welcome back</h1>
      <p class="auth-sub">Sign in to access your health dashboard</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="auth-alert"><%= error %></div>
      <% } %>
      <% if (typeof info !== 'undefined' && info) { %>
        <div class="auth-alert" style="background:#eef7f0;border-color:#bfe0c8;color:#2c6e49;"><%= info %></div>
      <% } %>

      <form method="POST" action="/login" class="auth-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="next" value="<%= typeof next !== 'undefined' ? next : '/dashboard' %>">
        <div class="auth-field">
          <label for="email">Email address</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" class="form-control" autocomplete="email">
        </div>
        <div class="auth-field">
          <label for="password" style="display:flex;justify-content:space-between;">
            Password <a href="/forgot-password" style="font-weight:400;color:var(--rose);font-size:13px;">Forgot password?</a>
          </label>
          <input type="password" id="password" name="password" required placeholder="Your password" class="form-control" autocomplete="current-password">
        </div>
        <button type="submit" class="auth-submit">Sign In
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>

      <p class="auth-switch">New to e-healthwatch? <a href="/signup">Create a free account</a></p>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
