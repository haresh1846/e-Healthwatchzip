<%- include('partials/header', { pageTitle: 'Reset Password — e-healthwatch' }) %>

<div class="auth-bg">
  <div class="auth-wrap auth-wrap--narrow">

    <div class="auth-card">
      <a href="/" class="auth-brand">
        <div class="auth-brand-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
        <span>e-health<strong>watch</strong></span>
      </a>

      <% if (!tokenValid) { %>
        <h1 class="auth-title">Link expired or invalid</h1>
        <p class="auth-sub">This password reset link is no longer valid. Reset links expire after 1 hour and can only be used once.</p>
        <p class="auth-switch" style="margin-top:20px;"><a href="/forgot-password">Request a new reset link &rarr;</a></p>
      <% } else { %>
        <h1 class="auth-title">Choose a new password</h1>
        <p class="auth-sub">Enter and confirm your new password below.</p>

        <% if (error) { %>
          <div class="auth-alert"><%= error %></div>
        <% } %>

        <form method="POST" action="/reset-password/<%= token %>" class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="auth-field">
            <label for="password">New password</label>
            <input type="password" id="password" name="password" required minlength="8" placeholder="At least 8 characters" class="form-control" autocomplete="new-password">
          </div>
          <div class="auth-field">
            <label for="confirm_password">Confirm new password</label>
            <input type="password" id="confirm_password" name="confirm_password" required minlength="8" placeholder="Repeat the new password" class="form-control" autocomplete="new-password">
          </div>
          <button type="submit" class="auth-submit">Save new password
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </form>
      <% } %>
    </div>

  </div>
</div>

<%- include('partials/footer') %>
