<%- include('partials/header') %>

<!------ About Banner ------->
<section id="banner-section">
  <div class="container-fluid">
    <div class="row">
      <div class="banner-placeholder text-center">
        <h2>BMD Result</h2>
      </div>
    </div>
  </div>
</section>

<!------ Result ------->
<section id="about-cont">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 col-md-10 col-sm-12 col-xs-12" style="margin:0 auto;float:none;">
        <h2 class="aboutpage-title">BMD result for <em><%= name %></em></h2>
        <div class="aboutpage-content">

          <%
            const colourMap = {
              green: { bg: '#F0FDF4', border: '#BBF7D0', badge: '#DCFCE7', badgeText: '#15803D', score: '#15803D' },
              amber: { bg: '#FFFBEB', border: '#FDE68A', badge: '#FEF3C7', badgeText: '#92400E', score: '#B45309' },
              rose:  { bg: '#FFF1F2', border: '#FECDD3', badge: '#FFE4E6', badgeText: '#9F1239', score: '#BE123C' },
            };
            const c = colourMap[classColor] || colourMap.green;
          %>

          <!-- Score + classification card -->
          <div style="background:<%= c.bg %>;border:1.5px solid <%= c.border %>;border-radius:16px;padding:28px 32px;margin-bottom:20px;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;">
              <div>
                <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:#94A3B8;margin-bottom:6px;">BMD Score (g/cm²)</div>
                <div style="font-size:48px;font-weight:900;color:<%= c.score %>;font-family:monospace;line-height:1;"><%= result %></div>
              </div>
              <div style="text-align:right;">
                <div style="background:<%= c.badge %>;color:<%= c.badgeText %>;display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:9999px;font-weight:800;font-size:15px;letter-spacing:.01em;margin-bottom:8px;">
                  <% if (classColor === 'green') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  <% } else if (classColor === 'amber') { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                  <% } else { %>
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  <% } %>
                  <%= classification %>
                </div>
                <div style="font-size:12px;color:#94A3B8;">WHO Classification</div>
              </div>
            </div>

            <!-- Visual band -->
            <div style="margin-top:20px;">
              <div style="display:flex;height:10px;border-radius:9999px;overflow:hidden;gap:2px;">
                <div style="flex:1;background:#DCFCE7;"></div>
                <div style="flex:1;background:#FEF3C7;"></div>
                <div style="flex:1;background:#FFE4E6;"></div>
              </div>
              <div style="display:flex;justify-content:space-between;font-size:10px;color:#94A3B8;margin-top:4px;font-weight:600;">
                <span>Normal ≥ 0.738</span>
                <span>Osteopenia 0.558 – 0.737</span>
                <span>Osteoporosis &lt; 0.558</span>
              </div>
            </div>
          </div>

          <!-- Clinical note -->
          <div style="background:#fff;border:1.5px solid #E2E8F0;border-radius:12px;padding:18px 22px;margin-bottom:24px;display:flex;align-items:flex-start;gap:12px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <div>
              <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#94A3B8;margin-bottom:4px;">Clinical Note</div>
              <p style="font-size:14px;color:#334155;line-height:1.65;margin:0;"><%= classNote %></p>
            </div>
          </div>

          <!-- Reference table -->
          <div style="background:#F8FAFC;border-radius:12px;padding:16px 20px;margin-bottom:24px;">
            <div style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#94A3B8;margin-bottom:12px;">Reference Ranges (WHO, Femoral Neck)</div>
            <table style="width:100%;border-collapse:collapse;font-size:13px;">
              <thead>
                <tr>
                  <th style="text-align:left;padding:6px 12px 6px 0;color:#64748B;font-weight:700;">Classification</th>
                  <th style="text-align:left;padding:6px 12px;color:#64748B;font-weight:700;">BMD Range (g/cm²)</th>
                  <th style="text-align:left;padding:6px 0;color:#64748B;font-weight:700;">T-score</th>
                </tr>
              </thead>
              <tbody>
                <tr style="border-top:1px solid #E2E8F0;">
                  <td style="padding:8px 12px 8px 0;"><span style="background:#DCFCE7;color:#15803D;padding:2px 10px;border-radius:9999px;font-weight:700;font-size:12px;">Normal</span></td>
                  <td style="padding:8px 12px;color:#334155;">≥ 0.738</td>
                  <td style="padding:8px 0;color:#334155;">≥ −1.0</td>
                </tr>
                <tr style="border-top:1px solid #E2E8F0;">
                  <td style="padding:8px 12px 8px 0;"><span style="background:#FEF3C7;color:#92400E;padding:2px 10px;border-radius:9999px;font-weight:700;font-size:12px;">Osteopenia</span></td>
                  <td style="padding:8px 12px;color:#334155;">0.558 – 0.737</td>
                  <td style="padding:8px 0;color:#334155;">−1.0 to −2.5</td>
                </tr>
                <tr style="border-top:1px solid #E2E8F0;">
                  <td style="padding:8px 12px 8px 0;"><span style="background:#FFE4E6;color:#9F1239;padding:2px 10px;border-radius:9999px;font-weight:700;font-size:12px;">Osteoporosis</span></td>
                  <td style="padding:8px 12px;color:#334155;">&lt; 0.558</td>
                  <td style="padding:8px 0;color:#334155;">&lt; −2.5</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Actions -->
          <div style="display:flex;gap:12px;flex-wrap:wrap;">
            <a href="/bmd.asp"
               style="display:inline-flex;align-items:center;gap:6px;background:var(--rose);color:#fff;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              New Calculation
            </a>
            <a href="/bmd-report/<%= recordId %>" target="_blank"
               style="display:inline-flex;align-items:center;gap:6px;background:#1E293B;color:#fff;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
              Print Report
            </a>
            <a href="/bmd-history"
               style="display:inline-flex;align-items:center;gap:6px;background:#F1F5F9;color:#334155;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
              View History
            </a>
          </div>

          <p style="font-size:11px;color:#94A3B8;margin-top:16px;line-height:1.6;">
            This result is generated by a mathematical prediction model and is for informational purposes only. It is not a substitute for a clinical DEXA scan or medical diagnosis. Always consult a qualified healthcare professional.
          </p>

        </div>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
